// Carnet — schéma v1
// tenant_id partout dès le jour 1 : le multi-clients restera trivial.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      String
  createdAt DateTime  @default(now())
  contacts  Contact[]
  orders    Order[]
  sessions  BotSession[]
  metrics   MetricSnapshot[]
  expenses  Expense[]
  partners  Partner[]
  settings  Settings?
}

/// Réglages par tenant — les valeurs nulles retombent sur l'env / les défauts.
model Settings {
  id                String   @id @default(cuid())
  tenantId          String   @unique
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  kmRate            Float?   // forfait km déductible (CHF/km, aller simple)
  depositPct        Int?     // acompte par défaut (%)
  digestHour        Int?     // heure du digest matin (0-23)
  nudgeHour         Int?     // heure des relances du soir (0-23)
  cronDigest        Boolean  @default(true)
  cronEveningNudges Boolean  @default(true)
  cronReviews       Boolean  @default(true)
  cronBirthday      Boolean  @default(true)
  cronMonthly       Boolean  @default(true)
  // délais des automatismes
  reviewDelayDays    Int?
  quoteFollowupDays  Int?
  leadFollowupHours  Int?
  birthdayLeadDays   Int?
  nudgeCooldownDays  Int?
  nudgeMaxPerEvening Int?
  cronFieldNudges    Boolean @default(true)
  fieldFollowupDays  Int?
  cronProduction     Boolean @default(true)
  productionLeadDays Int?
  cronHandover       Boolean @default(true)
  postHandoverHours  Int? // relance « c'est livré ? » N h après l'heure de remise
  gcalSync           Boolean @default(true)
  handoverLeadDays   Int?
  studioEnabled      Boolean @default(false)
  cronJournal        Boolean @default(true)
  cronThemes         Boolean @default(true)
  themeCheckDays     Int? // fréquence de la vigie des thèmes (jours)
  lastThemeCheckAt   DateTime? // dernier passage de la vigie
  gscProperty        String  @default("") // propriété Search Console (vide = dérivée de siteUrl)
  cronGsc            Boolean @default(true)
  gscCheckDays       Int? // fréquence de la vigie Search Console (jours)
  lastGscCheckAt     DateTime?
  gscIgnored         Json? // requêtes écartées à la main (normalisées)
  siteUrl            String  @default("") // URL publique du site vitrine (Journal)
  sitePathPrefix     String  @default("") // segment des pages Journal côté site (défaut « creations »)
  // marque blanche
  brandName          String?
  brandColor         String?
  lexicon            Json?
  reviewUrl         String   @default("")
  // paiement
  paymentDefault    String   @default("twint") // twint | virement
  twintNumber       String   @default("")
  accountHolder     String   @default("")
  iban              String   @default("")
  bankName          String   @default("")
  // assistant IA
  assistantActive       Boolean @default(true)
  assistantSignature    String  @default("")
  assistantInstructions String  @default("")
  // objectifs (page Cap)
  goalCaMensuel      Int?
  goalPanierMoyen    Int?
  goalAvisGoogle     Int?
  goalPartMariage    Int? // % du CA
  goalPartDecouple   Int? // % du CA hors sur-mesure
  goalInstagram      Int?
  milestones         Json? // jalons manuels cochés { cle: true }
  updatedAt         DateTime @updatedAt
}

/// Série de mesures mensuelles saisies (followers, avis…)
model MetricSnapshot {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  key       String   // instagram_followers | google_reviews
  month     String   // "2026-07"
  value     Int
  createdAt DateTime @default(now())

  @@unique([tenantId, key, month])
}

enum RevenueCategory {
  SUR_MESURE
  COLLECTION
  ATELIER
  BON_CADEAU
  DECORS
  B2B
}

enum Source {
  CONFIGURATEUR
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  EMAIL
  SMS
  TELEPHONE
  BOUCHE_A_OREILLE
  AUTRE
}

model Contact {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  firstName         String
  lastName          String   @default("")
  phone             String   @default("")
  email             String   @default("")
  instagram         String   @default("")
  facebook          String   @default("")
  source            Source   @default(AUTRE)
  consentNewsletter Boolean  @default(false)
  notes             String   @default("")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  orders            Order[]

  @@index([tenantId, lastName])
  @@index([tenantId, email])
  @@index([tenantId, phone])
}

enum OrderStatus {
  LEAD
  DEVIS_ENVOYE
  ACOMPTE_RECU
  EN_PRODUCTION
  LIVRE
  ANNULE
}

model Order {
  id              String      @id @default(cuid())
  tenantId        String
  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  contactId       String
  contact         Contact     @relation(fields: [contactId], references: [id])
  status          OrderStatus @default(LEAD)
  source          Source      @default(AUTRE)
  sourceDetail    String      @default("") // ex. « recommandée par Daniela »

  occasion        String      @default("")
  eventDate       DateTime?
  handoverAt      DateTime? // RDV de remise (retrait ou livraison), heure comprise
  gcalEventId     String      @default("") // événement Google Agenda lié
  celebrant       String      @default("")
  celebrantAge    Int?
  parts           Int?
  tiers           Int?
  biscuit         String      @default("")
  fourrages       String[]    @default([])
  themeNote       String      @default("")
  extras          Json?
  inspirationPhotos String[]  @default([])

  deliveryMode    String      @default("retrait") // retrait | livraison
  deliveryAddress String      @default("")
  deliveryKm      Int?

  priceQuoted     Int? // CHF
  depositPaidAt   DateTime?
  balancePaidAt   DateTime?
  deliveredAt     DateTime?

  revenueCategory RevenueCategory @default(SUR_MESURE)
  reviewAskedAt       DateTime?
  handoverAskedAt     DateTime? // relance post-remise envoyée
  lastNudgeAt         DateTime?
  anniversaryNudgedAt DateTime?
  cancelledAt         DateTime?
  depositCents     Int?
  balanceCents     Int?
  tipCents         Int? // pourboire encaissé à la livraison (au-delà du devis)
  partnerId        String?
  partner          Partner?   @relation(fields: [partnerId], references: [id])
  commissionPaidAt DateTime?

  notes           String      @default("")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  activities      Activity[]
  aiMessages      AiMessage[]

  @@index([tenantId, status])
  @@index([tenantId, eventDate])
  @@index([tenantId, partnerId])
}

/// Fil de conversation de l'assistant IA, partagé bot ↔ Carnet, par commande.
model AiMessage {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  role      String   @default("user") // user | assistant
  content   String
  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
}

model Activity {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type      String   @default("NOTE") // NOTE | STATUS | SYSTEM
  body      String
  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
}

/// État de conversation du bot Telegram (webhook stateless)
/* ------------------------------- Studio (contenu réseaux sociaux) ------ */

enum StudioAssetKind {
  VIDEO
  PHOTO
}

model StudioAsset {
  id         String          @id @default(cuid())
  tenantId   String
  kind       StudioAssetKind
  filePath   String // relatif à RECEIPTS_DIR (studio/<slug>/assets/…)
  thumbPath  String          @default("")
  durationSec Float?
  width      Int?
  height     Int?
  sizeBytes  Int             @default(0)
  note       String          @default("")
  source     String          @default("web") // web | bot | import
  orderId    String? // liaison commande optionnelle
  createdAt  DateTime        @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, orderId])
}

/* ------------------------------- Journal (pages SEO du site vitrine) --- */

enum JournalType {
  CREATION // liée à une commande — galerie d'abord
  ARTICLE  // conseil libre — texte d'abord
}

enum JournalTemplate {
  RECIT     // création · photos dans le récit
  GALERIE   // création · photos en vedette, texte court
  GUIDE     // article · question → réponse SEO
  ANNONCE   // article · billet éditorial (gâteau signature, prise de parole)
  SELECTION // article · sélection d'idées multi-créations (lot 2)
}

enum JournalFormat {
  ARTICLE // article illustré (photos dans le récit)
  VIDEO // clip principal + texte court
  DIAPORAMA // galerie en avant + texte minimal
}

enum JournalStatus {
  BROUILLON
  PROGRAMMEE
  PUBLIEE
}

enum JournalCategory {
  ANNIVERSAIRE
  MARIAGE
  CUPCAKES
  CONSEILS
  ATELIER
}

model JournalEntry {
  id              String          @id @default(cuid())
  tenantId        String
  type            JournalType     @default(CREATION)
  template        JournalTemplate @default(RECIT)
  format          JournalFormat   @default(ARTICLE)
  status          JournalStatus   @default(BROUILLON)
  category        JournalCategory @default(ANNIVERSAIRE)
  orderId         String? // commande source (créations)
  selectionOrderIds String[] @default([]) // template Sélection : les créations réunies
  slug            String
  title           String   @default("")
  metaTitle       String   @default("")
  metaDescription String   @default("")
  keywords        String[] @default([])
  story           String   @default("") // markdown
  coverAssetId    String   @default("")
  videoAssetId    String   @default("") // clip principal (format VIDEO)
  youtubeUrl      String   @default("") // optionnel : façade YouTube à la place du lecteur natif
  images          Json? // [{ assetId, alt }] — ordre d'affichage
  scheduledFor    DateTime?
  publishedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId, status, scheduledFor])
  @@index([tenantId, publishedAt])
}

/* Journal des appels IA — Laboratoire des prompts (ring ~100 entrées). */
model PromptLog {
  id        String   @id @default(cuid())
  kind      String // journal.suggestion | assistant.reponse | capture.analyse | …
  system    String   @default("")
  user      String   @default("")
  response  String   @default("")
  ok        Boolean  @default(true)
  ms        Int      @default(0)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

/* Donnée manquante « snoozée » ou abandonnée (dette de fiche). */
model FieldSnooze {
  id        String    @id @default(cuid())
  tenantId  String
  orderId   String
  field     String
  remindAt  DateTime?
  dismissed Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@unique([tenantId, orderId, field])
  @@index([tenantId, remindAt])
}

model BotSession {
  chatId    BigInt   @id
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  step      String   @default("idle")
  draft     Json?
  updatedAt DateTime @updatedAt
}

/// Dépense (ticket de caisse scanné ou saisie manuelle)
enum ExpenseCategory {
  MATIERES_PREMIERES
  EMBALLAGE
  MATERIEL
  DEPLACEMENT
  MARKETING
  AUTRE
}

enum ExpenseStatus {
  DRAFT
  CONFIRMED
}

model Expense {
  id          String          @id @default(cuid())
  tenantId    String
  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  status      ExpenseStatus   @default(DRAFT)
  date        DateTime        @default(now())
  merchant    String          @default("")
  totalCents  Int             @default(0)
  vat         Json?           // [{ rate: 2.6, amountCents: 61 }]
  category    ExpenseCategory @default(AUTRE)
  receiptPath String          @default("")
  ocrJson     Json?
  notes       String          @default("")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([tenantId, status, date])
}

/// Partenaire apporteur (commerce, photographe, salle…)
enum PartnerType {
  COMMERCE
  PHOTOGRAPHE
  WEDDING_PLANNER
  SALLE
  AUTRE
}

/* Candidature partenaire (formulaire public du site) — en attente de décision. */
model PartnerApplication {
  id          String      @id @default(cuid())
  tenantId    String
  business    String
  type        PartnerType @default(COMMERCE)
  typeLabel   String      @default("")
  contactName String      @default("")
  phone       String      @default("")
  city        String      @default("")
  message     String      @default("")
  status      String      @default("pending") // pending | accepted | declined
  createdAt   DateTime    @default(now())
  handledAt   DateTime?

  @@index([tenantId, status])
}

model Partner {
  id        String      @id @default(cuid())
  tenantId  String
  tenant    Tenant      @relation(fields: [tenantId], references: [id])
  name      String
  type      PartnerType @default(COMMERCE)
  code      String
  ratePct   Int         @default(10)
  contact   String      @default("")
  phone     String      @default("")
  city      String      @default("")
  active    Boolean     @default(true)
  createdAt DateTime    @default(now())
  orders    Order[]

  @@unique([tenantId, code])
}
