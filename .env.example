# --- Base de données (compose : service "db") ---
DATABASE_URL=postgresql://carnet:change-me@db:5432/carnet

# --- Back-office ---
AUTH_SECRET=genere-une-longue-chaine-aleatoire       # openssl rand -hex 32
ADMIN_PASSWORD=choisis-un-mot-de-passe-solide
APP_URL=https://carnet.mamangateau.ch
TENANT_NAME=Maman Gâteau
TENANT_SLUG=maman-gateau

# --- Bot Telegram ---
TELEGRAM_BOT_TOKEN=123456:ABC...                      # @BotFather
TELEGRAM_WEBHOOK_SECRET=genere-une-chaine-aleatoire   # openssl rand -hex 24
TELEGRAM_ALLOWED_CHAT_IDS=                            # ex: 123456789,987654321 (vide = premier /start affiche l'id)

# --- Webhook entrant du site (configurateur) ---
HOOK_SECRET=genere-une-chaine-aleatoire               # partagé avec le site

# --- OCR tickets (Gemini, projet GCP existant) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
RECEIPTS_DIR=/data/receipts

# --- Rappels & machine à avis ---
TZ=Europe/Zurich
DIGEST_HOUR=7
NUDGE_HOUR=20
GOOGLE_REVIEW_URL=            # fiche Google Business -> « Demander des avis » -> lien court g.page/r/...
GOOGLE_MAPS_SERVER_KEY=       # autocomplétion d'adresse (Places API) — même clé serveur que mamangateau.ch

# --- Google Agenda (synchronisation des remises) ---
# Compte de service (recommandé) : clé JSON encodée base64 + agenda partagé au compte
GCAL_SA_KEY_JSON_B64=
GCAL_CALENDAR_ID=mamangateau.ch@gmail.com
