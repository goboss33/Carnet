{
  "name": "carnet",
  "version": "0.1.0",
  "private": true,
  "description": "Carnet — le back-office des artisans et indépendants : commandes, contacts, relances.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:backfill": "prisma db execute --file prisma/backfill-kpi.sql --schema prisma/schema.prisma && prisma db execute --file prisma/backfill-orderno.sql --schema prisma/schema.prisma && prisma db execute --file prisma/backfill-payments.sql --schema prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma db push --force-reset && tsx prisma/seed.ts",
    "build:next": "next build"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@prisma/client": "^6.12.0",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@sparticuz/chromium": "^149.0.0",
    "@types/adm-zip": "^0.5.8",
    "@types/busboy": "^1.5.4",
    "@types/qrcode": "^1.5.6",
    "adm-zip": "^0.6.0",
    "busboy": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "grammy": "^1.34.0",
    "jose": "^5.9.6",
    "lucide-react": "^1.24.0",
    "next": "15.5.20",
    "pdf-lib": "^1.17.1",
    "puppeteer-core": "^25.3.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.33.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.0",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "prisma": "^6.12.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
